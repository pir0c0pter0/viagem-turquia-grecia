{
  "rules": {
    "ideias": {
      ".read": true,
      "$id": {
        ".write": true,
        ".validate": "newData.hasChildren(['titulo','dia','nome','categoria','ownerId'])",
        "titulo":    { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 200" },
        "texto":     { ".validate": "newData.isString() && newData.val().length <= 500" },
        "nome":      { ".validate": "newData.isString() && newData.val().length <= 50" },
        "dia":       { ".validate": "newData.isString() && newData.val().length <= 10" },
        "categoria": { ".validate": "newData.isString() && newData.val().length <= 20" },
        "link":      { ".validate": "newData.isString() && newData.val().length <= 300" },
        "ownerId":   { ".validate": "newData.isString() && newData.val().length <= 40" },
        "criadoEm":  { ".validate": "newData.isNumber()" },
        "likes":     { "$uid": { ".validate": "newData.isBoolean()" } },
        "$other":    { ".validate": false }
      }
    },
    "$other": { ".read": false, ".write": false }
  }
}
